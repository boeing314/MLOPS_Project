# Data files - tracked by DVC instead
data/processed/*
!data/processed/*.dvc
data/raw/*
!data/raw/*.dvc

# Python
__pycache__/
*.py[cod]
*.egg-info/
.env
venv/
.venv/

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Root .gitignore

```gitignore
# Python
venv/
__pycache__/
*.pyc
.pytest_cache/

# Env files
.env

# MLflow
mlruns/
mlflow.db

# DVC cache
.dvc/cache/

# Airflow runtime
airflow/logs/
airflow/*.db

# Frontend builds
dist/
coverage/

# OS / Editor
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
```

# frontend/.gitignore

```gitignore
node_modules/
dist/
coverage/
.env
*.log
