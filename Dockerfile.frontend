# ── Frontend Dockerfile ─────────────────────────────────────────────────────────
# Save as: Dockerfile.frontend

FROM node:20-slim

# Set working directory
WORKDIR /app

# Install dependencies
COPY frontend/package*.json ./
RUN npm install

# Copy frontend source
COPY frontend/ .

# Expose port
EXPOSE 5173

# Run Vite dev server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]